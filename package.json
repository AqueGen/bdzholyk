{
  "name": "bdzholyk",
  "version": "1.0.0",
  "private": true,
  "description": "Bdzholyk charity foundation website (Sumy, UA)",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --watch",
    "build": "npm run build:css",
    "dev": "concurrently \"npm:watch:css\" \"npx http-server -p 8765 -c-1 .\"",
    "serve": "npx http-server -p 8765 -c-1 ."
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "http-server": "^14.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
